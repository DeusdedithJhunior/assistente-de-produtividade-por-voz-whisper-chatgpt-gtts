import threading
import queue
import sounddevice as sd
import soundfile as sf
import numpy as np
import sys
import time

SAMPLERATE = 16000
CANAIS = 1
ARQUIVO_SAIDA = 'request_audio.wav'

# Fila para amostrar áudio em tempo real
q = queue.Queue()
gravando = False
stream = None

def audio_callback(indata, frames, time_info, status):
    if status:
        print(status, file=sys.stderr)
    q.put(indata.copy())

def iniciar_gravacao():
    global gravando, stream
    if gravando:
        return
    gravando = True
    stream = sd.InputStream(samplerate=SAMPLERATE, channels=CANAIS, callback=audio_callback)
    stream.start()
    print("🎙️ Gravando... Pressione ENTER nesta célula para PARAR.")

def parar_gravacao():
    global gravando, stream
    if not gravando:
        return
    gravando = False
    stream.stop()
    stream.close()
    frames = []
    while not q.empty():
        frames.append(q.get())
    if frames:
        audio = np.concatenate(frames, axis=0)
        sf.write(ARQUIVO_SAIDA, audio, SAMPLERATE, subtype='PCM_16')
        print(f"💾 Áudio salvo em: {ARQUIVO_SAIDA}")
    else:
        print("Nenhum áudio capturado.")

# --- fluxo da célula ---
iniciar_gravacao()
try:
    # Bloqueia até ENTER — enquanto isso, a callback vai empilhando áudio na fila
    input()  # pressione Enter quando quiser parar
finally:
    parar_gravacao()

# Opcional: tocar o áudio gravado
from IPython.display import Audio, display
display(Audio(ARQUIVO_SAIDA, autoplay=False))
